rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan untuk memvalidasi kepemilikan data
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Aturan untuk Root Koleksi Users
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Subkoleksi Kehamilan (pregnancies)
      match /pregnancies/{pregnancyId} {
        allow read, write: if isOwner(userId);

        // Subkoleksi Kick Counts
        match /kick_counts/{sessionId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId)
            && request.resource.data.totalKicks is number
            && request.resource.data.totalKicks >= 0;
          allow delete: if isOwner(userId);
        }

        // Subkoleksi Contractions
        match /contractions/{contractionId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId)
            && request.resource.data.startTime is timestamp
            && request.resource.data.endTime is timestamp
            && request.resource.data.endTime > request.resource.data.startTime;
          allow delete: if isOwner(userId);
        }

        // Subkoleksi Symptom Logs
        match /symptom_logs/{logId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Subkoleksi Anak (children)
      match /children/{childId} {
        allow read, write: if isOwner(userId);

        // Subkoleksi Growth Logs
        match /growth_logs/{logId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId)
            && request.resource.data.weightKg is number
            && request.resource.data.weightKg >= 0.5 && request.resource.data.weightKg <= 300
            && request.resource.data.heightCm is number
            && request.resource.data.heightCm >= 30 && request.resource.data.heightCm <= 300;
          allow delete: if isOwner(userId);
        }

        // Subkoleksi Vaccinations & Immunizations
        match /vaccinations/{vaccinationId} {
          allow read, write: if isOwner(userId);
        }
        match /immunizations/{vaccinationId} {
          allow read, write: if isOwner(userId);
        }

        // Subkoleksi Developmental Milestones & Milestones
        match /developmental_milestones/{milestoneId} {
          allow read, write: if isOwner(userId);
        }
        match /milestones/{milestoneId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
